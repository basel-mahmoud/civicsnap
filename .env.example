# Copy to .env.local and fill in from your Supabase project settings (API section).
# These are PUBLIC, browser-safe keys — the anon key is protected by Row Level Security.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-publishable-key

# Server-side only secrets (set as Supabase Edge Function secrets, NEVER committed):
#   ANTHROPIC_API_KEY   -> used by the classify-photo edge function
